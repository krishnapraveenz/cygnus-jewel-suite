{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cygnus Jewel Suite",
  "version": "0.4.0",
  "identifier": "com.cygnus.jewel",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cygnus Jewel Suite",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "maximized": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFDOUMyMUFBMTBGQ0Q4NjAKUldSZzJQd1FxaUdjSENqdG8zdGtrVCtYMUlPK1hzNVRDbHp0cnppcnVsN2E3SDY3V1Zja3VhbWwK",
      "endpoints": [
        "http://localhost:8787/api/update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dangerousInsecureTransportProtocol": true,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
